model Project {
  id              String                 @id @default(cuid())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  title           String
  description     String
  methodology     ProjectMethodologyEnum @default(SCRUM)
  minParticipants Int
  maxParticipants Int
  accessType      ProjectAccessTypeEnum
  difficulty      ProjectDifficultyEnum
  creditCost      Int?
  figmaProjectUrl String?
  publicCode      String?                @unique
  nextTaskNumber  Int                    @default(1)

  canceledAt                    DateTime?
  canceledById                  String?
  cancellationReason            String?
  refundCreditsOnCancellation   Boolean   @default(false)
  refundedCreditsOnCancellation Int       @default(0)

  tasks      Task[]
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  epics                 Epic[]
  sprints               Sprint[]
  members               User[]
  planningPokerSessions PlanningPokerSession[]
  invitations           ProjectInvitation[]

  @@index([canceledAt])
  @@schema("public")
}
