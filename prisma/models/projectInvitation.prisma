model ProjectInvitation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status             ProjectInvitationStatus @default(PENDING)
  creditCostSnapshot Int?
  respondedAt        DateTime?
  canceledAt         DateTime?

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("ProjectInvitationsReceived", fields: [userId], references: [id], onDelete: Cascade)

  invitedById String
  invitedBy   User   @relation("ProjectInvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)

  memberRemovalAudit    ProjectMemberRemovalAudit?
  creditPaymentEvidence ProjectCreditPaymentEvidence?

  @@index([userId, status])
  @@index([projectId, status])
  @@index([invitedById])
  @@schema("public")
}
